rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stars
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - The UID of the user
    //   - starId: string (required) - The ID of the star type
    //   - ip: string (required) - The user's IP address
    //   - timestamp: timestamp (required) - When it was created
    //   - position: map (required) - {x: number, y: number}
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStarSelection(data) {
      return data.keys().hasAll(['userId', 'starId', 'ip', 'timestamp', 'position']) &&
             data.userId == request.auth.uid &&
             data.starId is string &&
             data.ip is string &&
             data.timestamp is timestamp &&
             data.position is map &&
             data.position.x is number &&
             data.position.y is number;
    }

    match /stars/{userId} {
      // Anyone can read the star field
      allow read: if true;
      
      // Allow creation if the document doesn't exist yet
      // We don't use request.auth because sign-in is removed
      allow create: if !exists(/databases/$(database)/documents/stars/$(userId)) &&
                     request.resource.data.userId == userId;
      
      // Prevent any updates or deletes - once a star is picked, it's permanent
      allow update: if false;
      allow delete: if false;
    }
  }
}
