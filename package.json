{
  "name": "react-example",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && vite build --ssr src/entry-server.tsx && tsx scripts/prerender.ts && npm --prefix amitStarProject install && npm --prefix amitStarProject run build",
    "build:amit": "npm --prefix amitStarProject install && npm --prefix amitStarProject run build",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "preview": "vite preview",
    "start": "node --import tsx server.ts",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
